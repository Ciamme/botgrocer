# ============================================
# BotGrocer - Environment Configuration
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=production
HOST=0.0.0.0

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/botgrocer
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=5000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-session-secret-key-change-this-too
API_KEY_SALT=your-api-key-salt-for-agent-authentication

# CORS Configuration
CORS_ORIGIN=https://botgrocer.com,https://www.botgrocer.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX=100        # Max requests per window

# AI Agent Configuration
AGENT_API_ENABLED=true
AGENT_API_VERSION=v1
AGENT_DEFAULT_CREDITS=1000

# MCP (Model Context Protocol) Configuration
MCP_ENABLED=true
MCP_SERVER_PORT=3001
MCP_ALLOWED_ORIGINS=*

# UI Configuration
UI_THEME=auto  # auto, light, dark
UI_PRIMARY_COLOR=#CA279C
UI_FONT_FAMILY=SF Pro, SF Pro Rounded, -apple-system, BlinkMacSystemFont, sans-serif

# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,zh-CN,ja-JP
LOCALE_COOKIE_NAME=locale

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@botgrocer.com

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info
METRICS_ENABLED=true

# External Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Feature Flags
FEATURE_AGENT_REGISTRATION=true
FEATURE_SELF_EVOLUTION=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_MULTI_LANGUAGE=true